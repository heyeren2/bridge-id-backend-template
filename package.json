{
    "name": "bridge-id-backend",
    "version": "1.0.0",
    "description": "Analytics backend for bridge-id-sdk",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon --exec ts-node src/server.ts",
        "build": "tsup src/server.ts --format cjs --clean",
        "start": "node dist/server.js",
        "db:generate": "drizzle-kit generate:pg",
        "db:migrate": "drizzle-kit push:pg"
    },
    "license": "MIT",
    "dependencies": {
        "bridge-id-sdk": "^0.4.1",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "drizzle-orm": "^0.29.5",
        "express": "^4.22.1",
        "pg": "^8.20.0",
        "viem": "^2.47.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/node": "^20.19.37",
        "@types/pg": "^8.18.0",
        "drizzle-kit": "^0.20.18",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}